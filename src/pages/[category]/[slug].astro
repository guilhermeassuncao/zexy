---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Icon from "../../components/Icon.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

type EntryProps =
  | { kind: "offer"; entry: CollectionEntry<"offers"> }
  | { kind: "news"; entry: CollectionEntry<"news"> };

export async function getStaticPaths() {
  const [offers, news] = await Promise.all([getCollection("offers"), getCollection("news")]);

  return [
    ...offers.map((entry) => ({
      params: { category: entry.data.category, slug: entry.slug },
      props: { kind: "offer", entry }
    })),
    ...news.map((entry) => ({
      params: { category: entry.data.category, slug: entry.slug.split("/").at(-1) ?? entry.slug },
      props: { kind: "news", entry }
    }))
  ];
}

const { kind, entry } = Astro.props as EntryProps;
const { Content } = await render(entry);

const accentMap = {
  games: "text-red border-red/55 bg-black/45 shadow-[0_10px_30px_rgba(0,0,0,0.3)]",
  animes: "text-purple border-purple/55 bg-black/45 shadow-[0_10px_30px_rgba(0,0,0,0.3)]",
  series: "text-orange border-orange/55 bg-black/45 shadow-[0_10px_30px_rgba(0,0,0,0.3)]"
} as const;

const accentBarMap = {
  games: "bg-red shadow-[0_0_24px_rgba(248,115,89,0.45)]",
  animes: "bg-purple shadow-[0_0_24px_rgba(115,89,248,0.45)]",
  series: "bg-orange shadow-[0_0_24px_rgba(248,182,89,0.45)]"
} as const;

const categoryLabelMap = {
  games: "games",
  animes: "animes",
  series: "series & filmes"
} as const;
const postDateFormatter = new Intl.DateTimeFormat("pt-BR", {
  day: "2-digit",
  month: "2-digit",
  year: "numeric"
});

const pageTitle = `${entry.data.title} | Zexy`;
const headingCaseClass = kind === "news" ? "" : "lowercase";
const pageDescriptionSource =
  entry.body
    .split("\n\n")
    .map((part) => part.replace(/<[^>]+>/g, " ").replace(/[#*_`>\[\]\(\)-]/g, "").replace(/\s+/g, " ").trim())
    .find(Boolean) ?? entry.data.title;
const pageDescription =
  entry.data.description ??
  (pageDescriptionSource.length > 180 ? `${pageDescriptionSource.slice(0, 177).trimEnd()}...` : pageDescriptionSource);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://zexy.com.br").toString();
const publishedTime = entry.data.publishedAt.toISOString();
const modifiedTime = (entry.data.updatedAt ?? entry.data.publishedAt).toISOString();
const author = kind === "news" ? (entry.data.author ?? "Equipe Zexy") : "Equipe Zexy";
const breadcrumbs = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Zexy",
    item: Astro.site ?? "https://zexy.com.br"
  },
  {
    "@type": "ListItem",
    position: 2,
    name: categoryLabelMap[entry.data.category],
    item: new URL(`/${entry.data.category}`, Astro.site ?? "https://zexy.com.br").toString()
  },
  {
    "@type": "ListItem",
    position: 3,
    name: entry.data.title,
    item: canonicalUrl
  }
];
const articleStructuredData =
  kind === "news"
    ? [
        {
          "@context": "https://schema.org",
          "@type": "Article",
          headline: entry.data.title,
          description: pageDescription,
          image: [entry.data.image],
          datePublished: publishedTime,
          dateModified: modifiedTime,
          author: {
            "@type": "Person",
            name: author
          },
          publisher: {
            "@type": "Organization",
            name: "Zexy",
            logo: {
              "@type": "ImageObject",
              url: new URL("/og-image.png", Astro.site ?? "https://zexy.com.br").toString()
            }
          },
          mainEntityOfPage: canonicalUrl,
          articleSection: categoryLabelMap[entry.data.category],
          keywords: entry.data.tags?.join(", ")
        },
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          itemListElement: breadcrumbs
        }
      ]
    : [
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          itemListElement: breadcrumbs
        }
      ];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={entry.data.image}
  type={kind === "news" ? "article" : "website"}
  author={author}
  publishedTime={kind === "news" ? publishedTime : undefined}
  modifiedTime={kind === "news" ? modifiedTime : undefined}
  structuredData={articleStructuredData}
>
  <Header />

  <main class="site-container py-8 max-md:py-4">
    <article class="overflow-hidden rounded-[1rem] border border-gray-light bg-panel-gradient shadow-panel">
      <div class="relative isolate overflow-hidden">
        <img src={entry.data.image} alt={entry.data.alt ?? entry.data.title} class="aspect-[16/7] w-full object-cover max-md:aspect-[4/3]" />
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.08),transparent_34%),linear-gradient(180deg,rgba(19,18,26,0.08)_0%,rgba(19,18,26,0.34)_42%,rgba(19,18,26,0.94)_100%)]"></div>
        <div class="absolute inset-x-0 bottom-0 p-7 max-md:p-5">
          <div class="flex items-end gap-5 max-md:gap-4">
            <div class:list={["w-1.5 self-stretch rounded-full max-md:w-1", accentBarMap[entry.data.category]]}></div>

            <div>
              <div class:list={["mb-4 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-extrabold uppercase tracking-[0.14em] backdrop-blur-sm", accentMap[entry.data.category]]}>
                <Icon name={kind === "offer" ? "offers" : "news"} class="h-4 w-4 fill-none stroke-current stroke-2" />
                {categoryLabelMap[entry.data.category]}
              </div>

              <h1 class:list={["max-w-3xl text-balance font-orbitron text-[2.3rem] font-extrabold leading-[0.98] text-white drop-shadow-[0_6px_24px_rgba(0,0,0,0.65)] max-md:max-w-full max-md:text-[1.7rem]", headingCaseClass]}>
                {entry.data.title}
              </h1>

              {
                kind === "offer" ? (
                  <div class="mt-5 flex flex-wrap items-center gap-3">
                    <span class="rounded-full bg-orange px-3 py-1 text-xs font-extrabold text-white shadow-[0_8px_20px_rgba(0,0,0,0.3)]">
                      {entry.data.discount}
                    </span>
                    <span class="text-sm font-extrabold uppercase tracking-[0.08em] text-orange drop-shadow-[0_4px_14px_rgba(0,0,0,0.45)]">{entry.data.callout}</span>
                    <span class="text-[1.75rem] font-extrabold text-price-green drop-shadow-[0_4px_14px_rgba(0,0,0,0.45)]">{entry.data.price}</span>
                    <span class="text-sm text-lilac drop-shadow-[0_4px_14px_rgba(0,0,0,0.45)]">{entry.data.store}</span>
                  </div>
                ) : (
                  <div class="mt-4 flex flex-wrap items-center gap-3">
                    <p class="inline-flex rounded-full border border-white/10 bg-black/20 px-3 py-1 text-sm font-semibold tracking-[0.04em] text-lilac shadow-[0_8px_24px_rgba(0,0,0,0.28)] backdrop-blur-sm">
                      Publicado em {postDateFormatter.format(entry.data.publishedAt)}
                    </p>
                    {
                      entry.data.updatedAt && (
                        <p class="inline-flex rounded-full border border-white/10 bg-black/20 px-3 py-1 text-sm font-semibold tracking-[0.04em] text-lilac shadow-[0_8px_24px_rgba(0,0,0,0.28)] backdrop-blur-sm">
                          Atualizado em {postDateFormatter.format(entry.data.updatedAt)}
                        </p>
                      )
                    }
                  </div>
                )
              }

              {
                kind === "news" && (
                  <p class="mt-4 max-w-3xl text-sm leading-6 text-white/80">
                    {pageDescription}
                  </p>
                )
              }

              {
                kind === "news" && (
                  <p class="mt-3 text-sm font-semibold text-lilac">
                    Por {author}
                  </p>
                )
              }
            </div>
          </div>
        </div>
      </div>

      <div class="p-7 max-md:p-5">
        <div class="post-content mt-8">
          <Content />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

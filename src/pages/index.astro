---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import FeaturedSection from "../components/FeaturedSection.astro";
import NewsSection from "../components/NewsSection.astro";
// import OffersSection from "../components/OffersSection.astro";
import { getFeaturedListing, getNewsListing } from "../data/content";
import BaseLayout from "../layouts/BaseLayout.astro";

const homeFeatured = await getFeaturedListing("home");
const homeNews = await getNewsListing("home");
// const homeOffers = await getOffersListing("home");
---

<BaseLayout
  title="Zexy - games, animes e séries em um só lugar"
  description="Zexy reúne games, animes e séries em uma vitrine editorial com destaques e maratonas para descobrir o que vale seu tempo."
>
  <Header />

  <main class="site-main site-container">
    <FeaturedSection items={homeFeatured.items} label={homeFeatured.title} />
    <NewsSection title={homeNews.title} items={homeNews.items} ariaLabel={homeNews.title} />
    {/* <OffersSection title={homeOffers.title} categories={homeOffers.categories} items={homeOffers.items} /> */}
  </main>

  <Footer />
</BaseLayout>

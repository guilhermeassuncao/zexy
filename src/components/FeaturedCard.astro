---
import type { FeaturedItem } from "../data/home";

interface Props {
  item: FeaturedItem;
}

const { item } = Astro.props;

const categoryMap = {
  games: {
    text: "text-red",
    stripe: "bg-red"
  },
  animes: {
    text: "text-purple",
    stripe: "bg-purple"
  },
  series: {
    text: "text-orange",
    stripe: "bg-orange"
  }
} as const;

const sizeMap = {
  large: "min-h-[32.8125rem]",
  medium: "min-h-[15.8125rem]",
  small: "min-h-[10.0625rem]"
} as const;
---

<article
  class:list={[
    "group relative flex items-end overflow-hidden rounded-[0.625rem] bg-cover bg-center transition duration-300 ease-out hover:z-10 hover:scale-[1.06] hover:shadow-panel",
    sizeMap[item.size]
  ]}
  style={`background-image:url('${item.image}')`}
>
  <a href={item.href} class="absolute inset-0 z-10 block" aria-label={item.title}>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition duration-300 group-hover:from-black/70 group-hover:via-black/10"></div>
    <span class:list={["absolute bottom-0 left-0 h-[5.75rem] w-2", categoryMap[item.category].stripe]}></span>
    <div class="absolute inset-x-0 bottom-0 p-5 transition duration-300 group-hover:translate-y-[-0.125rem]">
      <span class:list={["mb-2.5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.06em]", categoryMap[item.category].text]}>
        {item.category}
        <span class:list={["h-[0.6875rem] w-[0.6875rem] rounded-sm", categoryMap[item.category].stripe]}></span>
      </span>
      <h2 class="max-w-[32.5rem] text-base font-extrabold leading-tight text-white transition duration-300 group-hover:text-white/95 max-md:text-sm">
        {item.title}
      </h2>
    </div>
  </a>
</article>

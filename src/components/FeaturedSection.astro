---
import FeaturedCard from "./FeaturedCard.astro";
import type { FeaturedItem } from "../data/home";

interface Props {
  items: FeaturedItem[];
  label?: string;
}

const { items, label = "Destaques" } = Astro.props;
const [mainCard, ...remainingCards] = items;
const secondColumnCards = remainingCards.slice(0, 2);
const thirdColumnCards = remainingCards.slice(2, 5);
const desktopGridClass =
  remainingCards.length === 0
    ? "grid-cols-1"
    : thirdColumnCards.length === 0
      ? "grid-cols-[1.35fr_1fr]"
      : "grid-cols-[1.35fr_1fr_1fr]";
---

{
  mainCard && (
    <section class="featured-section mt-8 pt-1.5 max-md:mt-3" aria-label={label}>
      <div class:list={["grid gap-4 max-md:grid-cols-1", desktopGridClass]}>
        <div>
          <FeaturedCard item={mainCard} />
        </div>

        {
          secondColumnCards.length > 0 && (
            <div class="grid gap-4">
              {secondColumnCards.map((item) => <FeaturedCard item={item} />)}
            </div>
          )
        }

        {
          thirdColumnCards.length > 0 && (
            <div class="grid gap-4">
              {thirdColumnCards.map((item) => <FeaturedCard item={item} />)}
            </div>
          )
        }
      </div>
    </section>
  )
}

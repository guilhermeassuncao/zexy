---
import FeaturedCard from "./FeaturedCard.astro";
import type { FeaturedItem } from "../data/home";

interface Props {
  items: FeaturedItem[];
  label?: string;
}

const { items, label = "Destaques" } = Astro.props;
const [mainCard, secondCard, thirdCard, fourthCard, fifthCard] = items;
---

<section class="featured-section mt-8 pt-1.5 max-md:mt-3" aria-label={label}>
  <div class="grid grid-cols-[1.35fr_1fr_1fr] gap-4 max-md:grid-cols-1">
    <div>
      <FeaturedCard item={mainCard} />
    </div>

    <div class="grid gap-4">
      <FeaturedCard item={secondCard} />
      <FeaturedCard item={thirdCard} />
    </div>

    <div class="grid gap-4">
      <FeaturedCard item={fourthCard} />
      <FeaturedCard item={fifthCard} />
    </div>
  </div>
</section>

---
import Icon from "./Icon.astro";
import type { PageContent } from "../data/pages";

interface Props {
  page: PageContent;
}

const { page } = Astro.props;
---

<section class="page-hero mt-10 max-md:mt-4">
  <div class="overflow-hidden rounded-[1.25rem] border border-gray-light bg-panel-gradient shadow-panel">
    <div class="grid gap-8 px-7 py-8 md:grid-cols-[1.2fr_0.8fr] md:px-10 md:py-10">
      <div>
        <p class:list={["mb-3 inline-flex items-center gap-2 text-xs font-extrabold uppercase tracking-[0.16em]", page.accentClass]}>
          <Icon name={page.icon} class="h-5 w-5 shrink-0" />
          canal zexy
        </p>
        <h1 class="font-orbitron text-[2.4rem] font-extrabold lowercase leading-none text-white max-md:text-[2rem]">
          {page.title}
        </h1>
        <p class="mt-4 max-w-2xl text-lg font-semibold leading-snug text-white/90 max-md:text-base">
          {page.subtitle}
        </p>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-lilac md:text-[0.9375rem]">
          {page.description}
        </p>
      </div>

      <div class:list={["grid gap-3 rounded-[1rem] border p-4 md:content-center", page.accentPanelClass]}>
        {
          page.heroStats.map((stat) => (
            <div class="rounded-xl border border-white/10 bg-black/10 px-4 py-3">
              <p class="text-[0.6875rem] font-bold uppercase tracking-[0.14em] text-lilac">{stat.label}</p>
              <p class="mt-1 font-orbitron text-[1.35rem] font-bold lowercase text-white">{stat.value}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

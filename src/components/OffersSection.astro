---
import ProductCard from "./ProductCard.astro";
import SectionTitle from "./SectionTitle.astro";
import { offerCategories, products } from "../data/home";
---

<section id="ofertas" class="offers-section mt-20 max-md:mt-12" aria-label="Ofertas da semana">
  <div class="mb-3.5 flex items-center justify-between gap-3">
    <SectionTitle title="ofertas" icon="offers" colorClass="text-blue" />
  </div>

  <div class="mb-4 flex flex-wrap gap-2 max-md:flex-nowrap max-md:overflow-x-auto max-md:pb-1">
    {
      offerCategories.map((category, index) => (
        <button type="button" class:list={["chip-button", index === 0 && "chip-button-active"]}>
          {category}
        </button>
      ))
    }
  </div>

  <div class="grid grid-cols-4 gap-x-4 gap-y-7 max-md:grid-cols-1">
    {products.map((item) => <ProductCard item={item} />)}
  </div>
</section>

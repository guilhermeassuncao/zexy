---
import NewsItem from "./NewsItem.astro";
import SectionTitle from "./SectionTitle.astro";
import type { NewsListItem } from "../data/content";

interface Props {
  title?: string;
  items?: NewsListItem[];
  ariaLabel?: string;
}

const { title = "notícias", items = [], ariaLabel = "Últimas notícias" } = Astro.props;
---

<section class="news-section mt-8 max-md:mt-5" aria-label={ariaLabel}>
  <SectionTitle title={title} icon="news" colorClass="text-news-heading" />

  <ul class="m-0 list-none p-0">
    {items.map((item) => <NewsItem item={item} />)}
  </ul>
</section>
